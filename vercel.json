{
    "rewrites": [
        {
            "source": "/admin",
            "destination": "https://hackoniotwebsitebackend-production.up.railway.app/admin"
        },
        {
            "source": "/admin/(.*)",
            "destination": "https://hackoniotwebsitebackend-production.up.railway.app/admin/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "https://hackoniotwebsitebackend-production.up.railway.app/api/$1"
        },
        {
            "source": "/socket.io/(.*)",
            "destination": "https://hackoniotwebsitebackend-production.up.railway.app/socket.io/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}